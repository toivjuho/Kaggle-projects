### Östersund Women ###

### Creating data sets from json files
relaylist <- list(ostrres = oster_relay)

racelist <- list(ostsres = oster_spr)

relaytreat <- lapply(relaylist, relayjson)
racetreat <- lapply(racelist, racejson)

# Östersund Women Relay
ostrmod <- relaytreat$ostrres |> 
  filter(!row_number() %in% relays) |> 
  select(1, 3, 4) |> 
  rename(ost_rel = 1) |> 
  mutate(ost_rel = as.numeric(ost_rel))

# Östersund Women Sprint
ostsmod <- racetreat$ostsres |> 
  rename(ost_spr = 1) |> 
  mutate(ost_spr = as.numeric(ost_spr))

# Merging races (in complete set includes all the pre-processed races)
# Individual races only
l <- list(ostsmod)

# All IBU World Cup races
k <- list(ostrmod, ostsmod)

position_women <- reduce(.x = l, merge, by = c('3', '4'), all = T)
all_races_women <- reduce(.x = k, merge, by = c('3', '4'), all = T)

#Renaming the last bits
position_women <- position_women |> 
  rename(name = 1,
         country = 2)

all_races_women <- all_races_women |> 
  rename(name = 1,
         country = 2)

# Creating positions table for individual races
position_women <- position_women[-24:-26]

position_women <- position_women |> 
  mutate(avg_pos = rowMeans(position_women[3:23], na.rm = T),
         sd = apply(position_women[3:23], 1, sd, na.rm = T),
         .before = ost_ind) |>
  mutate_at(5:25, dns) |> 
  mutate_at(3:4, round, 1)

# Creating positions table for all races
all_races_women <- all_races_women |> 
  mutate_at(3:34, dns)

# Creating a points table
points_women <- position_women |> 
  mutate_at(5:25, top40) |> 
  mutate_at(c(5:11, 13:17, 19, 21:24), points) |> 
  mutate_at(c(12, 18, 20, 25), mass) |> 
  mutate(total = rowSums(across(5:25)),
         .before = avg_pos) |> 
  mutate(points_per_pos = total / avg_pos,
         .before = ost_ind) |> 
  mutate_at(6, round, 1)

# Creating prize money table
prize_women <- all_races_women |> 
  mutate_at(c(3:5, 10, 16, 18, 23:24, 27, 30:31), top8) |> 
  mutate_at(c(6:9, 11:15, 17, 19:22, 25:26, 28:29, 32:34), top30) |> 
  mutate_at(c(3:5, 10, 16, 18, 23:24, 27, 30:31), prize_rel) |> 
  mutate_at(c(6:9, 11:15, 17, 19:22, 25:26, 28:29, 32:34), prize_ind) |> 
  mutate(total = rowSums(across(3:34)),
         .before = ost_rel) |> 
  mutate(total_solo = ost_ind + ost_spr + ost_purs + 
           hoch_spr + hoch_purs + 
           anne_spr + anne_purs + anne_mass +
           ober_spr + ober_purs +
           ruhp_spr + ruhp_purs +
           nove_indi + nove_mass +
           kont_indi + kont_mass +
           ote_spr + ote_purs +
           hol_spr + hol_purs + hol_mass,
         .before = ost_rel)

# Adding total races
races_women <- all_races_women |> 
  mutate_at(3:34, races) |> 
  mutate(total = rowSums(across(3:34)),
         .before = ost_rel) |> 
  mutate(total_solo = ost_ind + ost_spr + ost_purs + 
           hoch_spr + hoch_purs + 
           anne_spr + anne_purs + anne_mass +
           ober_spr + ober_purs +
           ruhp_spr + ruhp_purs +
           nove_indi + nove_mass +
           kont_indi + kont_mass +
           ote_spr + ote_purs +
           hol_spr + hol_purs + hol_mass,
         .before = ost_rel)

# Combining all the information into a new data set (bonus prize money was added by hand based on gathered information)
comb_women <- data.frame(name = position_women$name,
                         country = position_women$country,
                         race_total = races_women$total,
                         race_solo = races_women$total_solo,
                         avg_pos = points_women$avg_pos,
                         sd = points_women$sd,
                         points = points_women$total,
                         points_per_pos = points_women$points_per_pos,
                         prize_money_total = prize_women$total,
                         prize_money_solo = prize_women$total_solo,
                         prize_money_bonus = 0)

# More official data set created
official_women <- data.frame(name = position_women$name,
                             country = position_women$country,
                             points = points_women$total,
                             avg_pos = points_women$avg_pos,
                             race_total = races_women$total,
                             race_solo = races_women$total_solo,
                             sd = points_women$sd,
                             points_per_pos = points_women$points_per_pos,
                             prize_dist = comb_women$prize_money_total / sum(comb_women$prize_money_total),
                             prize_dist_solo = comb_women$prize_money_solo / sum(comb_women$prize_money_solo))

official_women <- official_women |> 
  mutate(prize_dist = prize_dist * 100,
         prize_dist_solo = prize_dist_solo * 100) |> 
  mutate_at(8, round, 1) |> 
  mutate_at(9:10, round, 3)

