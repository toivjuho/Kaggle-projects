# Women's races in order
oster_relay <- fromJSON('Östersund_W_Relay.json')
oster_spr <- fromJSON('Östersund_W_Sprint.json')

##### Data Pre-processing #####

# Saving some useful parts to save space
relays <- c(1, 6, 11, 16, 21, 26, 31, 36, 41, 46, 51, 56, 
