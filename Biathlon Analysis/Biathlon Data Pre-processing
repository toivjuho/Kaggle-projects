# Functions
relayjson <- function(df) {
  df <- data.frame(children = df$children$children) |> 
    select(matches("children.name"))
  
  df <- as.data.frame(t(df))
  
  df <- na.locf(df)
}

racejson <- function(df) {
  df <- data.frame(children = df$children$children) |> 
    select(matches("children.name"))
  
  df <- as.data.frame(t(df))
  
  df <- df |> 
    drop_na(5) |> 
    select(1, 3, 4)
}

top50 <- function(x){x = ifelse(x > 50, 0 ,x)}
top40 <- function(x){x = ifelse(x > 40, 0 ,x)}
top30 <- function(x){x = ifelse(x > 30, 0 ,x)}
top8 <- function(x){x = ifelse(x > 8, 0 ,x)}
dns <- function(x){x = ifelse(is.na(x), 120, x)}
races <- function(x){x = ifelse(x < 120, 1, 0)}
points <- function(x){x = recode(x, !!!setNames(ibucurr, 1:40))}
mass <- function(x){x = recode(x, !!!setNames(ibumass, 1:30))}
