# Women's top 15
points |> 
  filter(row_number() %in% c(1:15)) |> 
  mutate(name = fct_reorder(name, desc(points))) |> 
  ggplot(aes(name, points)) +
  geom_bar(aes(fill = points, width = 0.7), stat = 'identity') +
  scale_fill_gradient(low = "#3962D1", high = "#0E056E") +
  ggthemes::theme_clean() +
  labs(title = "Points table women top 15. Season 2025-2026",
       x = "Athlete",
       y = "Total Score",
       fill = "Total Score")

