# FIS vs IBU Prize distribution comparison
fis_women <- fis_women |> 
  mutate(prize_dist = (prize_total / sum(prize_total)*100)) |> 
  mutate_at(3, round, 3)

fis_men <- fis_men |> 
  mutate(prize_dist = (prize_total / sum(prize_total)*100)) |> 
  mutate_at(3, round, 3)

ibu_women <- overall_women |> 
  arrange(desc(prize_dist)) |> 
  filter(row_number() %in% c(1:120))

ibu_men <- overall_men |> 
  arrange(desc(prize_dist)) |> 
  filter(row_number() %in% c(1:120))


id <- 1:120

compare <- data.frame(id = id,
                      fis_women = fis_women$prize_dist,
                      fis_men = fis_men$prize_dist,
                      ibu_women = ibu_women$prize_dist,
                      ibu_men = ibu_men$prize_dist)

compare2 <- compare |> 
  filter(row_number() %in% c(1:30)) |> 
  pivot_longer(cols = c('fis_women', 'fis_men', 'ibu_women', 'ibu_men'),
               names_to = "competition",
               values_to = "prize_dist")

compare2 |> 
  ggplot(aes(x = id)) +
  geom_line(aes(y = prize_dist, group = competition, color = competition), linewidth = 1) +
  ggthemes::theme_clean() +
  theme(legend.background = element_rect(fill = "#E5E7F0", colour = 1),
        legend.position = c(0.7, 0.5)) +
  geom_vline(xintercept = c(15, 30), linetype = "dotted", alpha = 0.35) +
  scale_color_manual(values = c("#EB250F", "#E3A21A", "#40C924", "#0E056E")) +
  labs(title = "FIS vs IBU Prize money distribution comparison. Season 2025-2026",
       x = "Ranking",
       y = "Prize money distribution %",
       color = "Competition")

