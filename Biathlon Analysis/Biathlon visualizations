# Women's top 15 with average position as gradient and added line graph showing the amount of races per athlete
points |> 
  filter(row_number() %in% c(1:15)) |> 
  mutate(name = fct_reorder(name, desc(points))) |> 
  ggplot(aes(x = name)) +
  geom_bar(aes(y = points, fill = avg_pos, width = 0.7), stat = 'identity') +
  geom_point(aes(y = race_solo * 50), color = "#8A742A", size = 6) +
  geom_line(aes(y = race_solo * 50), group = 1, stat = 'identity', colour = "#E0CF15", size = 1.5, alpha = 0.6) +
  scale_fill_gradientn(colors = c("#0E056E", "#02C9FF"),
                       limits = c(6, 36)) +
  scale_y_continuous(sec.axis = sec_axis(~.*0.02, name = "Races competed")) +
  ggthemes::theme_clean() +
  labs(title = "Points table women top 15. Season 2025-2026",
       x = "Athlete",
       y = "Total Score",
       fill = "Average position")

